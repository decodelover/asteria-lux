PORT=5000
# NODE_ENV=production

# Use either DATABASE_URL or the individual DB_* variables below.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/luxury_store_db

DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=luxury_store_db

# Optional production settings
# DB_SSL=true
# STORE_NAME=Asteria Luxury House
# FRONTEND_URL=https://your-frontend-domain.com
# APP_BASE_URL=https://your-frontend-domain.com
# BACKEND_PUBLIC_URL=https://your-api-domain.com
# JWT_SECRET=replace-this-in-production
# JWT_EXPIRES_IN=7d
# ADMIN_EMAIL=admin@your-domain.com
# ADMIN_NAME=Store Owner
# ADMIN_PASSWORD=replace-this-admin-password
# EMAIL_VERIFICATION_REQUIRED=true
# EMAIL_VERIFICATION_WINDOW_HOURS=24
# STORE_CURRENCY=NGN
# STORE_LOCALE=en-NG
# STORE_SUPPORT_PHONE=2348000000000
# WHATSAPP_NUMBER=2348000000000
#
# SMTP settings for verification, order, newsletter, and contact emails
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM_EMAIL=Asteria Luxury House <no-reply@your-domain.com>
# SMTP_CONNECTION_TIMEOUT_MS=10000
# SMTP_GREETING_TIMEOUT_MS=10000
# SMTP_SOCKET_TIMEOUT_MS=15000
# MAIL_SEND_TIMEOUT_MS=15000
# STORE_SUPPORT_EMAIL=support@your-domain.com
#
# Paystack live/test keys
# PAYSTACK_PUBLIC_KEY=your-paystack-public-key
# PAYSTACK_SECRET_KEY=your-paystack-secret-key
# PAYSTACK_CALLBACK_URL=https://your-frontend-domain.com/?tab=cart
#
# Bank transfer checkout
# BANK_TRANSFER_ENABLED=true
# BANK_NAME=Example Bank
# BANK_ACCOUNT_NAME=Asteria Luxury House
# BANK_ACCOUNT_NUMBER=0123456789
# BANK_TRANSFER_INSTRUCTIONS=Transfer the exact order total, then upload a clear proof of payment.
