# Optional when the frontend is deployed separately.
# Leave unset for local development and for backend-served production builds.
VITE_API_BASE_URL=https://your-api-domain.com/api

# Optional currency/display settings.
# Keep these aligned with the backend STORE_CURRENCY value.
VITE_STORE_CURRENCY=NGN
VITE_STORE_LOCALE=en-NG
VITE_WHATSAPP_NUMBER=2348000000000
VITE_WHATSAPP_MESSAGE=Hello, I would like to make an enquiry about a product on Asteria Luxury House.
